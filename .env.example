# Docker Compose environment overrides for Phase III
AUTH_MODE=jwt
JWT_SECRET=change_me_phase3
JWT_EXPIRES_IN=7d
SESSION_SECRET=change_me_session_secret

# Bootstrap manager account for JWT mode demo
BOOTSTRAP_MANAGER_NAME=Manager
BOOTSTRAP_MANAGER_EMAIL=manager@lakeshore.local
BOOTSTRAP_MANAGER_PASSWORD=Manager123!

# Keycloak realm/client settings
KEYCLOAK_REALM=lakeshore
KEYCLOAK_CLIENT_ID=property-rental-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_BEARER_ONLY=true
KEYCLOAK_PUBLIC_CLIENT=false
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend URL used by logout redirect handlers
FRONTEND_URL=http://localhost:3000
