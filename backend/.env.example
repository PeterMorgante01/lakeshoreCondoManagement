AUTH_MODE=jwt
SERVICE_ROLE=monolith
PORT=5000
MONGO_URI=
JWT_SECRET=change_me_in_phase2
JWT_EXPIRES_IN=7d
BOOTSTRAP_MANAGER_NAME=
BOOTSTRAP_MANAGER_EMAIL=
BOOTSTRAP_MANAGER_PASSWORD=

# Keycloak Configuration (Optional)
# Set AUTH_MODE=keycloak and fill these values to enable delegated authentication
KEYCLOAK_AUTH_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_BEARER_ONLY=true
KEYCLOAK_PUBLIC_CLIENT=false
SESSION_SECRET=

# Frontend URL for Keycloak logout redirect
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development
